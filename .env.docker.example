# ==========================================
# Docker Environment Configuration
# Copy this file to .env.docker and fill in your values
# ==========================================

# Server Configuration
NODE_ENV=production
PORT=3001

# ==========================================
# DATABASE CONFIGURATION (Neon PostgreSQL)
# ==========================================
#
# Option 1: Use Neon Cloud Database (Recommended for Production)
# Get your connection string from: https://console.neon.tech/
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
#
DATABASE_URL=postgresql://user:password@ec2-xxx-xxx-xxx-xxx.compute-1.amazonaws.com:5432/your_db?sslmode=require

# Option 2: Use Local PostgreSQL (for local development)
# Uncomment and use the docker-compose PostgreSQL service
# DATABASE_URL=postgresql://finai:finai_secure_password@postgres:5432/finai

# ==========================================
# LOCAL POSTGRES CONFIGURATION
# ==========================================
# Only used if you're running PostgreSQL in docker-compose
# Change these if you want different credentials
POSTGRES_DB=finai
POSTGRES_USER=finai
POSTGRES_PASSWORD=finai_secure_password
POSTGRES_PORT=5432

# ==========================================
# EMAIL SERVICE (Resend)
# ==========================================
# Get your API key from https://resend.com/
RESEND_API_KEY=re_your_resend_api_key_here

# ==========================================
# GOOGLE OAUTH CONFIGURATION
# ==========================================
# Get these from https://console.cloud.google.com/
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ==========================================
# OPTIONAL CONFIGURATION
# ==========================================
# Custom server message
PING_MESSAGE=FinAi Server is running
