# ==========================================
# Database Configuration (Neon PostgreSQL)
# ==========================================
# Get your connection string from: https://console.neon.tech/
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
DATABASE_URL=postgresql://user:password@ec2-xxx-xxx-xxx-xxx.compute-1.amazonaws.com:5432/your_db?sslmode=require

# Or use local PostgreSQL (for development)
# DATABASE_URL=postgresql://finai:finai_password@localhost:5432/finai

# ==========================================
# Resend Email Service
# ==========================================
# Get your API key from https://resend.com/
RESEND_API_KEY=re_your_resend_api_key_here

# ==========================================
# Gmail OAuth Configuration
# ==========================================
# Get these from https://console.cloud.google.com/

# Your Google OAuth Client ID
# Already set in the app, but can be overridden here
VITE_GOOGLE_CLIENT_ID=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

# Your Google OAuth Client Secret (KEEP THIS PRIVATE - DO NOT COMMIT)
# Get this from Google Cloud Console
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Your Google OAuth Client ID (server-side, should match VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=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
