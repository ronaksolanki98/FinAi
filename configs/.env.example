# Gmail OAuth Configuration
VITE_GOOGLE_CLIENT_ID=your_gmail_client_id
GOOGLE_CLIENT_SECRET=your_gmail_client_secret
GOOGLE_CLIENT_ID=your_gmail_client_id_for_server

# Email/OTP Service
RESEND_API_KEY=your_resend_api_key
AUTH_FROM_EMAIL=no-reply@yourdomain.com

# Postgres database (use your Neon/Azure/Postgres URL)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
